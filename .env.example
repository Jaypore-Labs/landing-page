# ---------------------------------------------------------------------------
# Jaypore Labs landing page — environment variables
# Copy this file to `.env.local` for dev, or set them in Vercel project env.
# ---------------------------------------------------------------------------

# --- Supabase (contact-form inquiries) ---------------------------------------
# Where to find these:
#   Vercel Marketplace → Supabase integration (installs + wires env automatically),
#   OR Supabase Dashboard → Project Settings → API.
# The service-role key is SERVER-ONLY. Never expose it to the client / browser.
# If both are empty, the contact form gracefully falls back to server console
# logs so nothing gets lost while you finish setup.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Search-engine verification (optional but recommended) -------------------
# Google Search Console → Settings → Ownership verification → HTML tag → paste
# just the content="..." value (no quotes).
GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools → Site verification → meta tag → content value
BING_SITE_VERIFICATION=

# --- Analytics (optional) ----------------------------------------------------
# Google Analytics 4 → Admin → Data Streams → Measurement ID (G-XXXXXXXXXX)
# The "NEXT_PUBLIC_" prefix exposes it to the browser (safe; it's not a secret).
NEXT_PUBLIC_GA_ID=
